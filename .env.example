# Database
DATABASE_URL=postgresql://user:password@localhost:5432/viral_reels

# Instagram Credentials (опционально)
INSTAGRAM_USERNAME=your_username
INSTAGRAM_PASSWORD=your_password

# Redis (опционально)
REDIS_URL=redis://localhost:6379/0
USE_REDIS=false

# API Configuration
API_HOST=0.0.0.0
API_PORT=8000
API_WORKERS=4

# Scraping Settings
SCRAPE_DELAY_MIN=3
SCRAPE_DELAY_MAX=7
MAX_RETRIES=3
REQUEST_TIMEOUT=30
USE_PROXY=false
PROXY_URL=

# Viral Thresholds
VIRAL_MIN_VIEWS=10000
VIRAL_MIN_ENGAGEMENT_RATE=0.05
VIRAL_MAX_POST_AGE_HOURS=72

# Scheduler Intervals
COLLECT_INTERVAL_MINUTES=30
UPDATE_METRICS_INTERVAL_HOURS=2
RECALCULATE_SCORES_INTERVAL_HOURS=24

# Dashboard
DASHBOARD_PORT=8501